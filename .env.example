# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_random_secret_key_here_min_32_chars

# Google OAuth (Get from https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# MongoDB (Get connection string from MongoDB Atlas)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/leaveflow?retryWrites=true&w=majority

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000/api

